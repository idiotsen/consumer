---
import MacroBoardSection from "@/components/MacroBoardSection.astro";
import MarketTrackingBoardSection from "@/components/MarketTrackingBoardSection.astro";
import PageHero from "@/components/PageHero.astro";
import RealEstateHighFrequencyBoardSection from "@/components/RealEstateHighFrequencyBoardSection.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDateTime } from "@/lib/data";
import { loadMacroBoardData } from "@/lib/macro-board";
import { loadMarketTrackingBoardData } from "@/lib/market-tracking";
import { loadRealEstateHighFrequencyBoardData } from "@/lib/real-estate-high-frequency-board";
import { boardPages } from "@/lib/site";

export function getStaticPaths() {
  return boardPages.map((item) => ({
    params: {
      board: item.href.slice(1),
    },
    props: {
      pageMeta: item,
    },
  }));
}

const { pageMeta } = Astro.props;
const { macroLoad, board: macroBoard } = await loadMacroBoardData();
const { marketLoad, board: marketBoard } = await loadMarketTrackingBoardData();
const { highFrequencyLoad, board: highFrequencyBoard } = await loadRealEstateHighFrequencyBoardData();

function countBoardItems() {
  if (pageMeta.kind === "macro") {
    return macroBoard.sections.length;
  }
  if (pageMeta.kind === "market") {
    return marketBoard.sections.length;
  }
  return highFrequencyBoard.sections.length;
}

function countConnectedItems() {
  if (pageMeta.kind === "macro") {
    return macroBoard.sections.filter((item) => item.status === "ready").length;
  }
  if (pageMeta.kind === "market") {
    return marketBoard.sections.filter((item) => item.status === "ready").length;
  }
  return highFrequencyBoard.sections.filter((item) => item.status === "ready").length;
}

function countPendingItems() {
  if (pageMeta.kind === "macro") {
    return macroBoard.sections.filter((item) => item.status === "coming_soon").length;
  }
  if (pageMeta.kind === "market") {
    return marketBoard.sections.filter((item) => item.status === "coming_soon").length;
  }
  return highFrequencyBoard.sections.filter((item) => item.status === "coming_soon").length;
}

function countIssueItems() {
  if (pageMeta.kind === "macro") {
    return macroBoard.sections.filter((item) => item.status === "error").length;
  }
  if (pageMeta.kind === "market") {
    return marketBoard.sections.filter((item) => item.status === "error").length;
  }
  return highFrequencyBoard.sections.filter((item) => item.status === "error").length;
}

const totalItems = countBoardItems();
const connectedCount = countConnectedItems();
const pendingCount = countPendingItems();
const issueCount = countIssueItems();

const pageTitle = `${pageMeta.label}看板`;

const pageDescription =
  pageMeta.kind === "macro"
    ? `${pageMeta.label}独立页面，展示通胀、收入、居民资负表以及居民消费与消费意愿相关图表。`
    : pageMeta.kind === "market"
      ? `${pageMeta.label}独立页面，展示消费相关行业 PB-ROE、拥挤度以及券商金股消费股占比。`
      : `${pageMeta.label}独立页面，展示二手房价格与活跃度，以及新房价格与销售变化。`;

const boardDescription =
  pageMeta.kind === "macro"
    ? macroBoard.description
    : pageMeta.kind === "market"
      ? marketBoard.description
      : highFrequencyBoard.description;

const latestGeneratedAt =
  pageMeta.kind === "macro"
    ? macroLoad.data.updated_at
    : pageMeta.kind === "market"
      ? marketLoad.data.updated_at
      : highFrequencyLoad.data.updated_at;

const progressChip = `已接入 ${connectedCount} / ${totalItems} 个栏目`;

let statusChip = "当前全部内容可见";
if (issueCount > 0 && pendingCount > 0) {
  statusChip = `异常 ${issueCount} 项，待补充 ${pendingCount} 项`;
} else if (issueCount > 0) {
  statusChip = `异常 ${issueCount} 项`;
} else if (pendingCount > 0) {
  statusChip = `待补充 ${pendingCount} 项`;
}
---

<BaseLayout title={pageTitle} description={pageDescription} currentPath={pageMeta.href}>
  <PageHero
    eyebrow="Board"
    title={pageTitle}
    description={boardDescription}
    chips={[
      progressChip,
      statusChip,
      `最近生成 ${formatDateTime(latestGeneratedAt)}`,
    ]}
  />

  {
    pageMeta.kind === "macro" ? (
      <MacroBoardSection board={macroBoard} />
    ) : pageMeta.kind === "market" ? (
      <MarketTrackingBoardSection board={marketBoard} />
    ) : (
      <RealEstateHighFrequencyBoardSection board={highFrequencyBoard} />
    )
  }
</BaseLayout>
