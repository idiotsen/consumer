---
import MacroLineChart from "@/components/MacroLineChart.astro";
import MarketScatterTabs from "@/components/MarketScatterTabs.astro";
import { formatDateOnly } from "@/lib/data";
import type {
  MacroChartConfig,
  MarketTrackingBoardPayload,
  MarketTrackingCrowdednessGroup,
  MarketTrackingCrowdednessIndustry,
  MarketTrackingCoverageSummary,
  MarketTrackingRecommendedStock,
  MarketTrackingSection,
} from "@/lib/types";

interface Props {
  board: MarketTrackingBoardPayload;
}

const { board } = Astro.props;

function sectionById(sectionId: string): MarketTrackingSection | undefined {
  return board.sections.find((section) => section.section_id === sectionId);
}

function formatShareLabel(value: number): string {
  return `${value.toFixed(2)}%`;
}

function buildCompactNotice(coverage?: MarketTrackingCoverageSummary, fallback?: string): string | undefined {
  if (!coverage) {
    return fallback;
  }

  const parts: string[] = [];
  if (!coverage.broker_count_consistent) {
    parts.push(`券商家数 ${coverage.min_broker_count}-${coverage.max_broker_count} 家`);
  }
  if (!coverage.broker_members_consistent) {
    parts.push("券商名单随月份变化");
  }

  if (!parts.length) {
    return fallback;
  }

  return `${parts.join("，")}，更适合看趋势。`;
}

function buildChartExtrema(chart?: MacroChartConfig) {
  if (!chart?.series.length) {
    return null;
  }

  const primarySeries = chart.series[0];
  const points = primarySeries.values
    .map((value, index) => (value === null || value === undefined ? null : { index, value }))
    .filter((item): item is { index: number; value: number } => Boolean(item));

  if (!points.length) {
    return null;
  }

  const latestPoint = points[points.length - 1];
  const highestPoint = points.reduce((best, item) => (item.value > best.value ? item : best), points[0]);
  const lowestPoint = points.reduce((best, item) => (item.value < best.value ? item : best), points[0]);
  return {
    latest: {
      label: "最新",
      month: chart.labels[latestPoint.index] ?? chart.latest_time_text,
      value: formatShareLabel(latestPoint.value),
    },
    high: {
      label: "高点",
      month: chart.labels[highestPoint.index] ?? chart.latest_time_text,
      value: formatShareLabel(highestPoint.value),
    },
    low: {
      label: "低点",
      month: chart.labels[lowestPoint.index] ?? chart.latest_time_text,
      value: formatShareLabel(lowestPoint.value),
    },
  };
}

type ChartExtrema = NonNullable<ReturnType<typeof buildChartExtrema>>;

function buildBrokerShareFooter(
  coverage?: MarketTrackingCoverageSummary,
  extrema?: ChartExtrema | null,
): string | undefined {
  const parts: string[] = [];

  if (extrema) {
    parts.push(`最新占比 ${extrema.latest.value}`);
    parts.push(`最高占比 ${extrema.high.value}（${extrema.high.month}）`);
    parts.push(`最低占比 ${extrema.low.value}（${extrema.low.month}）`);
  }

  if (coverage) {
    parts.push(`券商 ${coverage.latest_broker_count} 家`);
    parts.push(`股票 ${coverage.latest_consumer_stock_count} 只`);
  }

  if (!parts.length) {
    return undefined;
  }

  return `，${parts.join("，")}`;
}

function stockPillLabel(stock: MarketTrackingRecommendedStock): string {
  return `${stock.name} · ${stock.broker_names[0] ?? "待补充"}`;
}

function brokerDeltaLabel(stock: MarketTrackingRecommendedStock): string | null {
  if (!stock.broker_count_delta) {
    return null;
  }

  return `${stock.broker_count_delta > 0 ? "↑" : "↓"} ${stock.broker_count_delta > 0 ? "+" : ""}${stock.broker_count_delta}`;
}

function brokerDeltaClassName(stock: MarketTrackingRecommendedStock): string {
  if ((stock.broker_count_delta ?? 0) > 0) {
    return "bg-rose-50 text-rose-600 ring-rose-200";
  }

  return "bg-emerald-50 text-emerald-700 ring-emerald-200";
}

function crowdednessWarningClassName(industry: MarketTrackingCrowdednessIndustry): string {
  return industry.high_crowding ? "bg-rose-100 text-rose-700" : "bg-emerald-100 text-emerald-700";
}

function crowdednessWarningLabel(industry: MarketTrackingCrowdednessIndustry): string {
  return industry.high_crowding ? "已预警" : "正常";
}

function crowdednessExclusionClassName(industry: MarketTrackingCrowdednessIndustry): string {
  return industry.excluded_signal ? "bg-amber-100 text-amber-800" : "bg-slate-100 text-slate-600";
}

function crowdednessExclusionLabel(industry: MarketTrackingCrowdednessIndustry): string {
  return industry.excluded_signal ? "排除信号" : "未触发";
}

function shouldShowCrowdednessIndustry(industry: MarketTrackingCrowdednessIndustry): boolean {
  return (
    industry.total_score !== 0 ||
    industry.crowded_20d_count !== 0 ||
    industry.high_crowding ||
    industry.excluded_signal
  );
}

function buildCrowdednessSummary(group: MarketTrackingCrowdednessGroup): {
  visibleIndustries: MarketTrackingCrowdednessIndustry[];
  hiddenCount: number;
  allHidden: boolean;
  hasNoData: boolean;
} {
  const visibleIndustries = group.industries.filter(shouldShowCrowdednessIndustry);
  const hiddenCount = group.industries.length - visibleIndustries.length;
  const hasNoData = group.industries.length === 0;
  return {
    visibleIndustries,
    hiddenCount,
    allHidden: !hasNoData && visibleIndustries.length === 0,
    hasNoData,
  };
}

const pbRoeSection = sectionById("consumer-pb-roe");
const crowdednessSection = sectionById("consumer-crowdedness");
const brokerShareSection = sectionById("consumer-broker-share");
const crowdednessGroups = crowdednessSection?.crowdedness_groups ?? [];
const crowdednessAsOf = crowdednessGroups[0]?.as_of_date;
const crowdednessDisplayGroups = crowdednessGroups.map((group) => ({
  ...group,
  ...buildCrowdednessSummary(group),
}));
const pbRoeCharts = pbRoeSection?.charts ?? [];
const coverage = brokerShareSection?.coverage;
const compactNotice = buildCompactNotice(coverage, brokerShareSection?.notice_message);
const brokerShareChart = brokerShareSection?.chart;
const shareExtrema = buildChartExtrema(brokerShareChart);
const recommendedStocks = brokerShareSection?.recommended_stocks ?? [];
const multiBrokerStocks = recommendedStocks.filter((stock) => stock.broker_count >= 2);
const singleBrokerStocks = recommendedStocks.filter((stock) => stock.broker_count === 1);
const chartFooterSuffix = buildBrokerShareFooter(coverage, shareExtrema);
---

<section class="grid gap-6">
  <div class="grid gap-6 xl:grid-cols-2">
    <article class="surface-panel p-6 xl:col-span-2">
      <div class="flex items-center justify-between gap-4">
        <h3 class="section-title">{pbRoeSection?.title ?? "消费相关行业 PB-ROE 图"}</h3>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
          {pbRoeSection?.status === "ready" && pbRoeCharts.length ? `已接入 ${pbRoeCharts.length} 张图` : pbRoeSection?.status === "error" ? "加载失败" : "待补充"}
        </span>
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-500">
        {pbRoeSection?.description ?? "后续将在这里补充消费相关行业 PB 分位数与 ROE 分位数对比。"}
      </p>
      {
        pbRoeSection?.status === "ready" && pbRoeSection?.notice_message ? (
          <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-2.5 text-xs leading-5 text-amber-800">
            {pbRoeSection.notice_message}
          </div>
        ) : null
      }
      {
        pbRoeSection?.status === "ready" && pbRoeCharts.length ? (
          <div class="mt-5">
            <MarketScatterTabs charts={pbRoeCharts} embedded />
          </div>
        ) : (
          <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
            {pbRoeSection?.placeholder_message ?? "消费相关行业 PB-ROE 图暂未接入。"}
          </div>
        )
      }
    </article>

    <article class="surface-panel p-6">
      <div class="flex items-center justify-between gap-4">
        <h3 class="section-title">{crowdednessSection?.title ?? "消费相关行业拥挤度跟踪"}</h3>
        {
          crowdednessSection?.status === "ready" && crowdednessAsOf ? (
            <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-semibold text-white">
              数据截至 {formatDateOnly(crowdednessAsOf)}
            </span>
          ) : (
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
              {crowdednessSection?.status === "error" ? "加载失败" : "待补充"}
            </span>
          )
        }
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-500">
        {crowdednessSection?.description ?? "后续将在这里补充消费相关行业拥挤度跟踪。"}
      </p>
      {
        crowdednessSection?.status === "ready" && crowdednessSection?.notice_message ? (
          <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-2.5 text-xs leading-5 text-amber-800">
            {crowdednessSection.notice_message}
          </div>
        ) : null
      }
      {
        crowdednessSection?.status === "ready" && crowdednessDisplayGroups.length ? (
          <div class="mt-5 grid gap-4">
            {
              crowdednessDisplayGroups.map((group) => (
                <section class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
                  <div class="flex items-center justify-between gap-3">
                    <h4 class="text-sm font-semibold text-slate-950">{group.title}</h4>
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold text-slate-700">
                      {group.hasNoData ? "暂无可用数据" : `${group.visibleIndustries.length} / ${group.industries.length} 个行业`}
                    </span>
                  </div>
                  {
                    group.hasNoData ? (
                      <div class="mt-4 rounded-2xl bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-500">
                        本次该分组暂无可用行业数据。
                      </div>
                    ) : group.allHidden ? (
                      <div class="mt-4 rounded-2xl bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-500">
                        当前 {group.industries.length} 个行业均未触发关注条件，暂不逐一展开。
                      </div>
                    ) : (
                      <div class="mt-4">
                        <div class="overflow-x-auto">
                          <table class="min-w-full text-left text-sm">
                            <thead class="text-xs uppercase tracking-[0.16em] text-slate-500">
                              <tr>
                                <th class="pb-3 font-medium">行业</th>
                                <th class="pb-3 font-medium">拥挤度得分</th>
                                <th class="pb-3 font-medium">即时预警</th>
                                <th class="pb-3 font-medium">排除信号</th>
                              </tr>
                            </thead>
                            <tbody>
                              {
                                group.visibleIndustries.map((industry: MarketTrackingCrowdednessIndustry) => (
                                  <tr class="border-t border-slate-100 align-top">
                                    <td class="py-3 pr-4">
                                      <p class="font-medium text-slate-900">{industry.industry_name}</p>
                                      {
                                        group.group_id === "l2" && industry.parent_l1_name ? (
                                          <p class="mt-1 text-xs text-slate-500">{industry.parent_l1_name}</p>
                                        ) : null
                                      }
                                    </td>
                                    <td class="py-3 pr-4">
                                      <p class="font-semibold text-slate-900">{industry.total_score.toFixed(0)}</p>
                                      <p class="mt-1 text-xs text-slate-500">20日拥挤 {industry.crowded_20d_count} 次</p>
                                    </td>
                                    <td class="py-3 pr-4">
                                      <span class:list={["inline-flex rounded-full px-3 py-1 text-xs font-semibold", crowdednessWarningClassName(industry)]}>
                                        {crowdednessWarningLabel(industry)}
                                      </span>
                                    </td>
                                    <td class="py-3">
                                      <span class:list={["inline-flex rounded-full px-3 py-1 text-xs font-semibold", crowdednessExclusionClassName(industry)]}>
                                        {crowdednessExclusionLabel(industry)}
                                      </span>
                                    </td>
                                  </tr>
                                ))
                              }
                            </tbody>
                          </table>
                        </div>
                        {
                          group.hiddenCount > 0 ? (
                            <p class="mt-3 text-sm leading-6 text-slate-500">
                              其余 {group.hiddenCount} 个行业当前拥挤度得分、20日拥挤次数、即时预警和排除信号均未触发关注条件，暂不逐一展开。
                            </p>
                          ) : null
                        }
                      </div>
                    )
                  }
                </section>
              ))
            }
          </div>
        ) : (
          <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
            {crowdednessSection?.placeholder_message ?? "消费相关行业拥挤度图暂未接入。"}
          </div>
        )
      }
    </article>

    {
      brokerShareChart ? (
        <article class="surface-panel p-6 xl:col-span-2">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <h3 class="section-title">{brokerShareSection?.title}</h3>
              <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-500">{brokerShareSection?.description}</p>
            </div>
            {
              coverage ? (
                <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-semibold text-white">
                  最新月份 {coverage.latest_month}
                </span>
              ) : null
            }
          </div>

          {
            compactNotice ? (
              <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-2.5 text-xs leading-5 text-amber-800">
                {compactNotice}
              </div>
            ) : null
          }

          <div class="mt-5 grid gap-5 xl:grid-cols-[1.45fr_0.9fr]">
            <div>
              <MacroLineChart chart={brokerShareChart} embedded footerSuffix={chartFooterSuffix} />
            </div>

            <div class="grid gap-4">
              <article class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <h4 class="text-sm font-semibold text-slate-950">最新月份消费推荐个股</h4>
                    <p class="mt-1 text-xs leading-5 text-slate-500">
                      {coverage ? `${coverage.latest_month} 券商金股中的消费个股与推荐券商。` : "展示最新月份的消费个股与推荐券商。"}
                    </p>
                  </div>
                  <span class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold text-slate-700">
                    {recommendedStocks.length} 只
                  </span>
                </div>

                {
                  recommendedStocks.length ? (
                    <div class="mt-4 space-y-4">
                      {
                        multiBrokerStocks.length ? (
                          <div class="grid gap-2.5 sm:grid-cols-2 2xl:grid-cols-3">
                            {
                              multiBrokerStocks.map((stock) => (
                                <div class="rounded-xl border border-slate-200 bg-slate-50 px-2.5 py-2">
                                  <div class="flex flex-wrap items-center gap-1.5">
                                    <p class="text-sm font-semibold leading-5 text-slate-900">{stock.name}</p>
                                    {
                                      brokerDeltaLabel(stock) ? (
                                        <span class:list={["rounded-full px-2 py-0.5 text-[10px] font-semibold ring-1", brokerDeltaClassName(stock)]}>
                                          {brokerDeltaLabel(stock)}
                                        </span>
                                      ) : null
                                    }
                                  </div>
                                  <div class="mt-1.5 flex flex-wrap gap-1">
                                    {
                                      stock.broker_names.map((broker) => (
                                        <span class="rounded-full bg-white px-2 py-0.5 text-[10px] font-medium text-slate-700 ring-1 ring-slate-200">
                                          {broker}
                                        </span>
                                      ))
                                    }
                                  </div>
                                </div>
                              ))
                            }
                          </div>
                        ) : null
                      }

                      {
                        singleBrokerStocks.length ? (
                          <div class:list={["flex flex-wrap gap-2", multiBrokerStocks.length ? "border-t border-slate-200 pt-4" : ""]}>
                            {
                              singleBrokerStocks.map((stock) => (
                                <span class="rounded-full bg-slate-50 px-3 py-1.5 text-[11px] font-medium text-slate-700 ring-1 ring-slate-200">
                                  {stockPillLabel(stock)}
                                </span>
                              ))
                            }
                          </div>
                        ) : null
                      }
                    </div>
                  ) : (
                    <div class="mt-4 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
                      最新月份暂未识别到消费个股推荐。
                    </div>
                  )
                }
              </article>
            </div>
          </div>
        </article>
      ) : (
        <article class="surface-panel p-6 xl:col-span-2">
          <div class="flex items-center justify-between gap-4">
            <h3 class="section-title">券商金股中消费个股占比统计</h3>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">待补充</span>
          </div>
          <p class="mt-3 text-sm leading-6 text-slate-500">
            {brokerShareSection?.description ?? "后续将在这里补充券商金股中消费个股占比走势与最新推荐名单。"}
          </p>
          <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
            {brokerShareSection?.placeholder_message ?? "券商金股消费占比统计暂未接入。"}
          </div>
        </article>
      )
    }
  </div>
</section>
