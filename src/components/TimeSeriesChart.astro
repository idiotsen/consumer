---
import type { TimeSeriesItem } from "@/lib/types";

interface Props {
  title: string;
  description: string;
  series: TimeSeriesItem[];
}

const { title, description, series } = Astro.props;
const chartId = `chart-${crypto.randomUUID()}`;
---

<section class="surface-panel overflow-hidden">
  <div class="border-b border-slate-200 px-5 py-4">
    <h2 class="section-title">{title}</h2>
    <p class="mt-2 text-sm text-slate-500">{description}</p>
  </div>

  {
    series.length > 0 ? (
      <>
        <div
          class="h-[22rem] p-5"
          data-time-series-chart
          data-canvas-id={chartId}
          data-payload-id={`${chartId}-payload`}
        >
          <canvas id={chartId}></canvas>
        </div>
        <div class="grid gap-4 border-t border-slate-200 bg-slate-50/70 p-5 md:grid-cols-3">
          {
            series.map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                <p class="text-sm font-semibold text-slate-700">{item.label}</p>
                <p class="mt-2 text-xs text-slate-500">{item.source}</p>
                <p class="mt-3 text-sm text-slate-500">{item.unit}</p>
              </div>
            ))
          }
        </div>
      </>
    ) : (
      <div class="p-5 text-sm text-slate-500">当前没有可绘制的时间序列。</div>
    )
  }
</section>

<script is:inline type="application/json" id={`${chartId}-payload`}>{JSON.stringify(series)}</script>

<script>
  import { Chart, registerables } from "chart.js";

  Chart.register(...registerables);

  const palette = ["#0f766e", "#1d4ed8", "#ea580c", "#dc2626"];

  document.querySelectorAll("[data-time-series-chart]").forEach((root) => {
    if (!(root instanceof HTMLElement)) {
      return;
    }

    const canvasId = root.dataset.canvasId;
    const payloadId = root.dataset.payloadId;
    if (!canvasId || !payloadId) {
      return;
    }

    const canvas = document.getElementById(canvasId);
    const payloadNode = document.getElementById(payloadId);
    if (!(canvas instanceof HTMLCanvasElement) || !payloadNode?.textContent) {
      return;
    }

    const series = JSON.parse(payloadNode.textContent);
    if (!Array.isArray(series) || series.length === 0) {
      return;
    }

    const labels = series[0].dates;

    new Chart(canvas, {
      type: "line",
      data: {
        labels,
        datasets: series.map((item, index) => ({
          label: `${item.label} (${item.unit})`,
          data: item.values,
          borderColor: palette[index % palette.length],
          backgroundColor: `${palette[index % palette.length]}22`,
          pointRadius: 0,
          borderWidth: 2.5,
          tension: 0.28,
          fill: false,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: "index",
          intersect: false,
        },
        plugins: {
          legend: {
            position: "bottom",
            labels: {
              boxWidth: 14,
              usePointStyle: true,
            },
          },
        },
        scales: {
          x: {
            grid: {
              color: "rgba(148, 163, 184, 0.18)",
            },
          },
          y: {
            grid: {
              color: "rgba(148, 163, 184, 0.18)",
            },
          },
        },
      },
    });
  });
</script>
