---
import MacroComboChart from "@/components/MacroComboChart.astro";
import MacroLineChart from "@/components/MacroLineChart.astro";
import type { MacroSection, RealEstateHighFrequencyBoardPayload } from "@/lib/types";

interface Props {
  board: RealEstateHighFrequencyBoardPayload;
}

const { board } = Astro.props;

function sectionById(sectionId: string): MacroSection | undefined {
  return board.sections.find((section) => section.section_id === sectionId);
}

const sectionCards = [
  {
    section: sectionById("second-hand-housing"),
    fallbackTitle: "二手房",
    fallbackCopy: "二手房高频数据暂未接入。",
  },
  {
    section: sectionById("new-home"),
    fallbackTitle: "新房",
    fallbackCopy: "新房高频数据暂未接入。",
  },
];
---

<section class="grid gap-6 xl:grid-cols-2">
  {
    sectionCards.map(({ section, fallbackTitle, fallbackCopy }) => (
      section?.status === "ready" && section.charts?.length ? (
        <article class="surface-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <h3 class="section-title">{section.title}</h3>
            </div>
            <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-semibold text-white">
              {section.charts.length} 张图
            </span>
          </div>

          {section.placeholder_message ? (
            <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-800">
              {section.placeholder_message}
            </div>
          ) : null}

          <div class="mt-6 grid gap-5">
            {section.charts.map((chart) => (
              <div>
                {chart.chart_type === "combo" ? (
                  <MacroComboChart chart={chart} embedded />
                ) : (
                  <MacroLineChart chart={chart} embedded />
                )}
              </div>
            ))}
          </div>
        </article>
      ) : (
        <article class="surface-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <h3 class="section-title">{section?.title ?? fallbackTitle}</h3>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
              {section?.status === "error" ? "加载失败" : "待补充"}
            </span>
          </div>
          <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
            {section?.placeholder_message ?? fallbackCopy}
          </div>
        </article>
      )
    ))
  }
</section>
