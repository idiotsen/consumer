---
import MacroComboChart from "@/components/MacroComboChart.astro";
import MacroLineChart from "@/components/MacroLineChart.astro";
import type { MacroBoardPayload, MacroSection } from "@/lib/types";

interface Props {
  board: MacroBoardPayload;
}

const { board } = Astro.props;

function sectionById(sectionId: string): MacroSection | undefined {
  return board.sections.find((section) => section.section_id === sectionId);
}

const inflationSection = sectionById("inflation");
const incomeSection = sectionById("income");
const balanceSheetSection = sectionById("household-balance-sheet");
const consumptionSection = sectionById("household-consumption-intention");
const consumptionCharts = consumptionSection?.charts ?? [];
---

<section class="grid gap-6">
  <div class="grid gap-6 xl:grid-cols-2">
    {
      inflationSection?.chart ? (
        <MacroLineChart chart={inflationSection.chart} />
      ) : (
        <article class="surface-panel p-6">
          <h3 class="section-title">通胀</h3>
          <p class="mt-3 text-sm leading-6 text-slate-500">
            {inflationSection?.placeholder_message ?? "通胀数据暂未生成。"}
          </p>
        </article>
      )
    }

    {
      incomeSection?.chart ? (
        <MacroLineChart chart={incomeSection.chart} />
      ) : (
        <article class="surface-panel p-6">
          <h3 class="section-title">收入</h3>
          <p class="mt-3 text-sm leading-6 text-slate-500">{incomeSection?.placeholder_message ?? "收入数据暂未生成。"}</p>
        </article>
      )
    }

    {
      balanceSheetSection?.chart ? (
        balanceSheetSection.chart.chart_type === "combo" ? (
          <MacroComboChart chart={balanceSheetSection.chart} />
        ) : (
          <MacroLineChart chart={balanceSheetSection.chart} />
        )
      ) : (
        <article class="surface-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <h3 class="section-title">居民资负表</h3>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">待补充</span>
          </div>
          <p class="mt-3 text-sm leading-6 text-slate-500">
            {balanceSheetSection?.description ?? "后续将在这里补充居民资产负债表相关数据。"}
          </p>
          <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
            {balanceSheetSection?.placeholder_message ?? "居民资负表数据暂未接入。"}
          </div>
        </article>
      )
    }

    {
      consumptionSection?.status === "ready" && consumptionCharts.length > 0 ? (
        <article class="surface-panel p-6 xl:col-span-2">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <h3 class="section-title">{consumptionSection.title}</h3>
              <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-500">{consumptionSection.description}</p>
            </div>
            <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-semibold text-white">
              {consumptionCharts.length} 张图
            </span>
          </div>

          {
            consumptionSection.placeholder_message ? (
              <div class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-800">
                {consumptionSection.placeholder_message}
              </div>
            ) : null
          }

          <div class="mt-6 grid gap-5 xl:grid-cols-3">
            {
              consumptionCharts.map((chart) => (
                <div>
                  <MacroLineChart chart={chart} embedded />
                </div>
              ))
            }
          </div>
        </article>
      ) : (
        <article class="surface-panel p-6 xl:col-span-2">
          <div class="flex items-center justify-between gap-4">
            <h3 class="section-title">居民消费与消费意愿</h3>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">待补充</span>
          </div>
          <p class="mt-3 text-sm leading-6 text-slate-500">
            {consumptionSection?.description ?? "后续将在这里补充居民消费、消费倾向与消费者信心相关数据。"}
          </p>
          <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
            {consumptionSection?.placeholder_message ?? "居民消费与消费意愿数据暂未接入。"}
          </div>
        </article>
      )
    }
  </div>
</section>
