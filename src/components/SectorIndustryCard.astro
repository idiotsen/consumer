---
import {
  formatCompactCurrency,
  formatDateOnly,
  formatNullableNumber,
  formatNullablePercent,
  formatSignedPercent,
} from "@/lib/data";
import type { SectorIndustryPanel } from "@/lib/types";

interface Props {
  industry: SectorIndustryPanel;
}

const { industry } = Astro.props;

const statusClassMap: Record<string, string> = {
  ready: "bg-emerald-100 text-emerald-800",
  partial: "bg-amber-100 text-amber-800",
  error: "bg-rose-100 text-rose-800",
  coming_soon: "bg-slate-100 text-slate-700",
};

const crowdednessClassMap: Record<string, string> = {
  拥挤: "bg-rose-100 text-rose-800",
  中性: "bg-amber-100 text-amber-800",
  不拥挤: "bg-emerald-100 text-emerald-800",
  数据不足: "bg-slate-100 text-slate-700",
};

const alignmentClassMap: Record<string, string> = {
  expensive_vs_roe: "bg-rose-100 text-rose-800",
  balanced: "bg-sky-100 text-sky-800",
  cheap_vs_roe: "bg-emerald-100 text-emerald-800",
  empty: "bg-slate-100 text-slate-700",
};

const crowdednessLabel = industry.crowdedness?.label ?? "数据不足";
---

<article class="surface-panel p-5">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm font-semibold text-slate-900">{industry.name}</p>
      <p class="mt-1 text-xs text-slate-500">
        {industry.market} · {industry.ts_code}
      </p>
    </div>
    <span class:list={["rounded-full px-3 py-1 text-xs font-semibold", statusClassMap[industry.status] ?? statusClassMap.coming_soon]}>
      {
        industry.status === "coming_soon"
          ? "待补充"
          : industry.status === "partial"
            ? "部分可用"
            : industry.status === "error"
              ? "加载失败"
              : "已接入"
      }
    </span>
  </div>

  <p class="mt-4 text-sm leading-6 text-slate-500">{industry.status_message}</p>

  {
    industry.status === "coming_soon" ? (
      <div class="mt-5 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-5 text-sm leading-6 text-slate-500">
        这个位置先保留给港股物业。等找到稳定、可复现的 Tushare 替代口径后，再补入估值与股价诊断。
      </div>
    ) : industry.status === "error" ? (
      <div class="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-5 text-sm leading-6 text-rose-800">
        当前没有成功生成这个行业的日频行情，请先检查 Tushare 权限、行业代码和 ETL 日志。
      </div>
    ) : (
      <>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl bg-slate-50 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">最新收盘</p>
            <p class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">
              {formatNullableNumber(industry.latest_close ?? null, 2)}
            </p>
            <p class="mt-1 text-sm text-slate-500">{formatDateOnly(industry.latest_trade_date)}</p>
          </div>
          <div class="rounded-2xl bg-slate-50 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">当日涨跌幅</p>
            <p class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">
              {formatSignedPercent(industry.latest_pct_change ?? null, 2)}
            </p>
            <p class="mt-1 text-sm text-slate-500">用于判断最新交易情绪</p>
          </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">PB 当前值</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{formatNullableNumber(industry.pb ?? null, 2)}</p>
          </div>
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">PB 5年分位</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">
              {formatNullablePercent(industry.pb_percentiles?.five_year ?? null, 1)}
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">ROE 当前值</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">
              {formatNullablePercent(industry.pb_roe_alignment?.current_roe ?? null, 1)}
            </p>
            <p class="mt-1 text-xs text-slate-500">
              口径期末：{formatDateOnly(industry.pb_roe_alignment?.current_roe_period ?? undefined)}
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">ROE 20季分位</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">
              {formatNullablePercent(industry.pb_roe_alignment?.roe_pct_20q ?? null, 1)}
            </p>
          </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">交易拥挤度</p>
            <div class="mt-2 flex items-center gap-3">
              <p class="text-lg font-semibold text-slate-900">
                {formatNullablePercent(industry.crowdedness?.score ?? null, 1)}
              </p>
              <span class:list={["rounded-full px-3 py-1 text-xs font-semibold", crowdednessClassMap[crowdednessLabel] ?? crowdednessClassMap["数据不足"]]}>
                {crowdednessLabel}
              </span>
            </div>
            <p class="mt-2 text-xs text-slate-500">
              成交额分位 {formatNullablePercent(industry.crowdedness?.amount_pct ?? null, 1)} ·
              成交额/流通市值分位 {formatNullablePercent(industry.crowdedness?.turnover_ratio_pct ?? null, 1)}
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">PB 与 ROE 匹配</p>
            <div class="mt-2 flex items-center gap-3">
              <p class="text-lg font-semibold text-slate-900">
                {formatSignedPercent(industry.pb_roe_alignment?.match_gap ?? null, 1)}
              </p>
              <span class:list={["rounded-full px-3 py-1 text-xs font-semibold", alignmentClassMap[industry.pb_roe_alignment?.status ?? "empty"] ?? alignmentClassMap.empty]}>
                {industry.pb_roe_alignment?.label ?? "数据不足"}
              </span>
            </div>
            <p class="mt-2 text-xs text-slate-500">
              PB 3年分位 {formatNullablePercent(industry.pb_roe_alignment?.pb_pct_3y ?? null, 1)} ·
              PB 5年分位 {formatNullablePercent(industry.pb_roe_alignment?.pb_pct_5y ?? null, 1)}
            </p>
          </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl bg-slate-50 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">成交额</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{formatCompactCurrency(industry.amount ?? null)}</p>
          </div>
          <div class="rounded-2xl bg-slate-50 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-500">流通市值</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{formatCompactCurrency(industry.float_mv ?? null)}</p>
            <p class="mt-1 text-xs text-slate-500">当前成分股数量：{industry.member_count ?? 0}</p>
          </div>
        </div>
      </>
    )
  }
</article>
