---
import { formatMetricValue } from "@/lib/data";
import type { MetricItem } from "@/lib/types";

interface Props {
  metric: MetricItem;
}

const { metric } = Astro.props;

const accentClass =
  metric.status === "critical"
    ? "from-rose-500/12 to-rose-50 border-rose-200/70"
    : metric.status === "warning"
      ? "from-amber-500/12 to-amber-50 border-amber-200/70"
      : "from-sky-500/12 to-sky-50 border-sky-200/70";
---

<article class:list={["surface-panel bg-gradient-to-br p-5", accentClass]}>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm font-semibold text-slate-600">{metric.label}</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">
        {formatMetricValue(metric.value, metric.unit)}
      </p>
    </div>
    <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold text-white">
      {metric.trend}
    </span>
  </div>
  <p class="mt-4 text-sm font-medium text-slate-700">{metric.delta_text}</p>
  <p class="mt-2 text-sm leading-6 text-slate-500">{metric.description}</p>
</article>
