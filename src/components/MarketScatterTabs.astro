---
import type { MarketTrackingScatterChartConfig } from "@/lib/types";

interface Props {
  charts: MarketTrackingScatterChartConfig[];
  embedded?: boolean;
}

const { charts, embedded = false } = Astro.props;
const tabsId = `market-scatter-tabs-${crypto.randomUUID()}`;
const chartIds = charts.map((chart) => chart.chart_id);
const defaultChart =
  charts.find((chart) => chart.chart_id === "consumer-pb-roe-l1") ??
  charts[0];
const defaultChartId = defaultChart?.chart_id ?? "";
const payloadPrefix = `${tabsId}-payload-`;
const canvasId = `${tabsId}-canvas`;
const titleId = `${tabsId}-title`;
const descriptionId = `${tabsId}-description`;
const footerId = `${tabsId}-footer`;
const panelId = `${tabsId}-panel`;
const wrapperClass = embedded
  ? "overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-[0_18px_40px_rgba(15,23,42,0.06)]"
  : "surface-panel overflow-hidden";
const chartHeightClass = embedded ? "h-[26rem] md:h-[28rem]" : "h-[32rem]";

function tabLabel(chartId: string): string {
  if (chartId === "consumer-pb-roe-l1") {
    return "一级行业";
  }
  if (chartId === "consumer-pb-roe-l2") {
    return "二级行业";
  }
  return chartId;
}
---

<section
  class={wrapperClass}
  data-market-scatter-tabs
  data-chart-ids={chartIds.join(",")}
  data-default-chart-id={defaultChartId}
  data-canvas-id={canvasId}
  data-title-id={titleId}
  data-description-id={descriptionId}
  data-footer-id={footerId}
  data-payload-prefix={payloadPrefix}
>
  <div class="border-b border-slate-200 px-5 py-4">
    <div class="flex flex-wrap items-center gap-2" role="tablist" aria-label="PB-ROE 图层级切换">
      {
        charts.map((chart) => (
          <button
            type="button"
            role="tab"
            id={`${tabsId}-${chart.chart_id}-tab`}
            aria-controls={panelId}
            aria-selected={chart.chart_id === defaultChartId ? "true" : "false"}
            data-chart-tab
            data-chart-id={chart.chart_id}
            class:list={[
              "rounded-full px-4 py-2 text-sm font-semibold transition-colors",
              chart.chart_id === defaultChartId
                ? "bg-slate-950 text-white"
                : "bg-slate-100 text-slate-600 hover:bg-slate-200",
            ]}
          >
            {tabLabel(chart.chart_id)}
          </button>
        ))
      }
    </div>
    <div class="mt-4">
      <h4 id={titleId} class="text-sm font-semibold text-slate-950">{defaultChart?.title}</h4>
      <p id={descriptionId} class="mt-2 text-sm leading-6 text-slate-500">{defaultChart?.description}</p>
    </div>
  </div>

  <div id={panelId} role="tabpanel" aria-labelledby={`${tabsId}-${defaultChartId}-tab`}>
    <div class:list={[chartHeightClass, "p-5"]}>
      <canvas id={canvasId}></canvas>
    </div>
    <div id={footerId} class="px-5 pb-4 text-left text-xs text-slate-400">
      {defaultChart ? `${defaultChart.latest_label} ${defaultChart.latest_time_text}` : ""}
    </div>
  </div>
</section>

{
  charts.map((chart) => (
    <script
      is:inline
      type="application/json"
      id={`${payloadPrefix}${chart.chart_id}`}
      set:html={JSON.stringify(chart)}
    ></script>
  ))
}

<script>
  import { renderMarketScatterChart, type ScatterChartPayload } from "@/lib/market-scatter-render";

  document.querySelectorAll("[data-market-scatter-tabs]").forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.scatterTabsBound === "true") {
      return;
    }

    const chartIds = (root.dataset.chartIds ?? "")
      .split(",")
      .map((value) => value.trim())
      .filter(Boolean);
    const defaultChartId = root.dataset.defaultChartId ?? chartIds[0];
    const canvas = document.getElementById(root.dataset.canvasId ?? "");
    const titleNode = document.getElementById(root.dataset.titleId ?? "");
    const descriptionNode = document.getElementById(root.dataset.descriptionId ?? "");
    const footerNode = document.getElementById(root.dataset.footerId ?? "");
    const payloadPrefix = root.dataset.payloadPrefix ?? "";
    const panel = root.querySelector('[role="tabpanel"]');

    if (
      !(canvas instanceof HTMLCanvasElement) ||
      !(titleNode instanceof HTMLElement) ||
      !(descriptionNode instanceof HTMLElement) ||
      !(footerNode instanceof HTMLElement) ||
      !(panel instanceof HTMLElement)
    ) {
      return;
    }

    const canvasElement = canvas;
    const titleElement = titleNode;
    const descriptionElement = descriptionNode;
    const footerElement = footerNode;
    const panelElement = panel;

    const payloads = new Map<string, ScatterChartPayload>();
    chartIds.forEach((chartId) => {
      const payloadNode = document.getElementById(`${payloadPrefix}${chartId}`);
      if (!payloadNode?.textContent) {
        return;
      }
      const payload = JSON.parse(payloadNode.textContent);
      payloads.set(chartId, payload);
    });

    const buttons = Array.from(root.querySelectorAll("[data-chart-tab]")).filter(
      (button): button is HTMLButtonElement => button instanceof HTMLButtonElement,
    );
    if (!buttons.length || !payloads.size) {
      return;
    }

    function activate(chartId: string) {
      const payload = payloads.get(chartId) ?? payloads.get(defaultChartId) ?? Array.from(payloads.values())[0];
      if (!payload) {
        return;
      }

      titleElement.textContent = payload.title;
      descriptionElement.textContent = payload.description;
      footerElement.textContent = `${payload.latest_label} ${payload.latest_time_text}`;
      const activeButton = buttons.find((button) => button.dataset.chartId === payload.chart_id);
      if (activeButton?.id) {
        panelElement.setAttribute("aria-labelledby", activeButton.id);
      }

      buttons.forEach((button) => {
        const isActive = button.dataset.chartId === payload.chart_id;
        button.setAttribute("aria-selected", isActive ? "true" : "false");
        button.setAttribute("tabindex", isActive ? "0" : "-1");
        button.classList.toggle("bg-slate-950", isActive);
        button.classList.toggle("text-white", isActive);
        button.classList.toggle("bg-slate-100", !isActive);
        button.classList.toggle("text-slate-600", !isActive);
        button.classList.toggle("hover:bg-slate-200", !isActive);
      });

      renderMarketScatterChart(canvasElement, payload);
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        if (button.dataset.chartId) {
          activate(button.dataset.chartId);
        }
      });
    });

    root.dataset.scatterTabsBound = "true";
    activate(defaultChartId);
  });
</script>
