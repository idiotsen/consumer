---
import type { AlertItem } from "@/lib/types";
import { withBasePath } from "@/lib/site";

interface Props {
  alerts: AlertItem[];
}

const { alerts } = Astro.props;

const alertStyles: Record<string, string> = {
  critical: "border-rose-200 bg-rose-50 text-rose-900",
  warning: "border-amber-200 bg-amber-50 text-amber-900",
  info: "border-sky-200 bg-sky-50 text-sky-900",
  healthy: "border-emerald-200 bg-emerald-50 text-emerald-900",
};
---

<div class="grid gap-4">
  {
    alerts.map((alert) => (
      <a href={alert.link ? withBasePath(alert.link) : "#"} class:list={["surface-panel block p-5 transition hover:-translate-y-0.5", alertStyles[alert.level] ?? alertStyles.info]}>
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em]">{alert.level}</p>
            <h2 class="mt-2 text-lg font-semibold">{alert.title}</h2>
            <p class="mt-2 text-sm leading-6 opacity-90">{alert.description}</p>
          </div>
          <span class="rounded-full bg-white/70 px-3 py-1 text-xs font-semibold">查看</span>
        </div>
      </a>
    ))
  }
</div>
