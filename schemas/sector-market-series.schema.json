{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "updated_at",
    "source",
    "stale_after_minutes",
    "status",
    "status_message",
    "series"
  ],
  "properties": {
    "updated_at": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "stale_after_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error"]
    },
    "status_message": {
      "type": "string"
    },
    "series": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "board_id",
          "ts_code",
          "label",
          "source",
          "benchmark_code",
          "benchmark_label",
          "latest_trade_date",
          "dates",
          "close",
          "normalized_close",
          "benchmark_close",
          "benchmark_normalized_close",
          "relative_to_benchmark",
          "pb",
          "amount",
          "turnover_value_ratio"
        ],
        "properties": {
          "board_id": {
            "type": "string",
            "minLength": 1
          },
          "ts_code": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "benchmark_code": {
            "type": "string",
            "minLength": 1
          },
          "benchmark_label": {
            "type": "string",
            "minLength": 1
          },
          "latest_trade_date": {
            "type": "string"
          },
          "dates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "close": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "normalized_close": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "benchmark_close": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "benchmark_normalized_close": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "relative_to_benchmark": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "pb": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "amount": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          },
          "turnover_value_ratio": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": ["number", "null"]
            }
          }
        }
      }
    }
  }
}
