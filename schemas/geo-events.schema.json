{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["updated_at", "source", "stale_after_minutes", "center", "events"],
  "properties": {
    "updated_at": { "type": "string" },
    "source": { "type": "string" },
    "stale_after_minutes": { "type": "integer", "minimum": 1 },
    "status": { "type": "string" },
    "status_message": { "type": "string" },
    "center": {
      "type": "object",
      "required": ["lat", "lng", "zoom"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "zoom": { "type": "number" }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "summary", "lat", "lng", "status", "started_at", "source"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "status": { "type": "string" },
          "started_at": { "type": "string" },
          "source": { "type": "string" },
          "link": { "type": "string" }
        }
      }
    }
  }
}
