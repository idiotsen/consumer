{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "updated_at",
    "source",
    "stale_after_minutes",
    "status",
    "status_message",
    "board_id",
    "title",
    "description",
    "sections"
  ],
  "properties": {
    "updated_at": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "stale_after_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error"]
    },
    "status_message": {
      "type": "string"
    },
    "board_id": {
      "type": "string",
      "const": "market-tracking"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "title", "description", "status"],
        "properties": {
          "section_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ready", "coming_soon", "error"]
          },
          "placeholder_message": {
            "type": "string"
          },
          "notice_message": {
            "type": "string"
          },
          "chart": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "chart_id",
              "title",
              "description",
              "chart_type",
              "x_axis_label",
              "latest_label",
              "latest_time_text",
              "labels",
              "series"
            ],
            "properties": {
              "chart_id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "chart_type": {
                "type": "string",
                "const": "line"
              },
              "x_axis_label": {
                "type": "string",
                "minLength": 1
              },
              "latest_label": {
                "type": "string",
                "minLength": 1
              },
              "latest_time_text": {
                "type": "string",
                "minLength": 1
              },
              "show_point_markers": {
                "type": "boolean"
              },
              "latest_changes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "basis_label", "direction", "delta_value", "unit"],
                  "properties": {
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "basis_label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "direction": {
                      "type": "string",
                      "enum": ["up", "down", "flat"]
                    },
                    "delta_value": {
                      "type": "number"
                    },
                    "unit": {
                      "type": "string"
                    }
                  }
                }
              },
              "labels": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "series": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["series_id", "label", "unit", "y_axis_id", "span_gaps", "values"],
                  "properties": {
                    "series_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "unit": {
                      "type": "string"
                    },
                    "y_axis_id": {
                      "type": "string",
                      "enum": ["left", "right"]
                    },
                    "span_gaps": {
                      "type": "boolean"
                    },
                    "show_point_markers": {
                      "type": "boolean"
                    },
                    "values": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": ["number", "null"]
                      }
                    }
                  }
                }
              }
            }
          },
          "charts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "chart_id",
                "title",
                "description",
                "chart_type",
                "x_axis_label",
                "y_axis_label",
                "latest_label",
                "latest_time_text",
                "points"
              ],
              "properties": {
                "chart_id": {
                  "type": "string",
                  "minLength": 1
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "chart_type": {
                  "type": "string",
                  "const": "scatter"
                },
                "x_axis_label": {
                  "type": "string",
                  "minLength": 1
                },
                "y_axis_label": {
                  "type": "string",
                  "minLength": 1
                },
                "latest_label": {
                  "type": "string",
                  "minLength": 1
                },
                "latest_time_text": {
                  "type": "string",
                  "minLength": 1
                },
                "points": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "ts_code",
                      "industry_name",
                      "level",
                      "parent_l1_name",
                      "pb_percentile_5y",
                      "roe_percentile_5y",
                      "latest_pb",
                      "latest_pb_date",
                      "latest_roe",
                      "latest_roe_period",
                      "is_consumer_related"
                    ],
                    "properties": {
                      "ts_code": {
                        "type": "string",
                        "minLength": 1
                      },
                      "industry_name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "level": {
                        "type": "string",
                        "enum": ["L1", "L2"]
                      },
                      "parent_l1_name": {
                        "type": ["string", "null"]
                      },
                      "pb_percentile_5y": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "roe_percentile_5y": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "latest_pb": {
                        "type": "number"
                      },
                      "latest_pb_date": {
                        "type": "string",
                        "minLength": 1
                      },
                      "latest_roe": {
                        "type": "number"
                      },
                      "latest_roe_period": {
                        "type": "string",
                        "minLength": 1
                      },
                      "is_consumer_related": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          },
          "coverage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "latest_month",
              "months_covered",
              "latest_broker_count",
              "min_broker_count",
              "max_broker_count",
              "broker_count_consistent",
              "broker_members_consistent",
              "latest_total_recommendations",
              "latest_consumer_recommendations",
              "latest_consumer_stock_count",
              "latest_consumer_share_pct",
              "comparison_note"
            ],
            "properties": {
              "latest_month": {
                "type": "string",
                "minLength": 1
              },
              "months_covered": {
                "type": "integer",
                "minimum": 1
              },
              "latest_broker_count": {
                "type": "integer",
                "minimum": 1
              },
              "min_broker_count": {
                "type": "integer",
                "minimum": 1
              },
              "max_broker_count": {
                "type": "integer",
                "minimum": 1
              },
              "broker_count_consistent": {
                "type": "boolean"
              },
              "broker_members_consistent": {
                "type": "boolean"
              },
              "latest_total_recommendations": {
                "type": "integer",
                "minimum": 0
              },
              "latest_consumer_recommendations": {
                "type": "integer",
                "minimum": 0
              },
              "latest_consumer_stock_count": {
                "type": "integer",
                "minimum": 0
              },
              "latest_consumer_share_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "comparison_note": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "recommended_stocks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ts_code", "name", "industry_name", "broker_count", "broker_names"],
              "properties": {
                "ts_code": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "industry_name": {
                  "type": "string",
                  "minLength": 1
                },
                "broker_count": {
                  "type": "integer",
                  "minimum": 1
                },
                "previous_broker_count": {
                  "type": ["integer", "null"],
                  "minimum": 0
                },
                "broker_count_delta": {
                  "type": ["integer", "null"]
                },
                "broker_names": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          },
          "crowdedness_groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["group_id", "title", "as_of_date", "industries"],
              "properties": {
                "group_id": {
                  "type": "string",
                  "enum": ["l1", "l2"]
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "as_of_date": {
                  "type": "string",
                  "minLength": 1
                },
                "industries": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "ts_code",
                      "industry_name",
                      "level",
                      "parent_l1_name",
                      "total_score",
                      "high_crowding",
                      "excluded_signal",
                      "crowded_20d_count"
                    ],
                    "properties": {
                      "ts_code": {
                        "type": "string",
                        "minLength": 1
                      },
                      "industry_name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "level": {
                        "type": "string",
                        "enum": ["L1", "L2"]
                      },
                      "parent_l1_name": {
                        "type": ["string", "null"]
                      },
                      "total_score": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 4
                      },
                      "high_crowding": {
                        "type": "boolean"
                      },
                      "excluded_signal": {
                        "type": "boolean"
                      },
                      "crowded_20d_count": {
                        "type": "integer",
                        "minimum": 0
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
