{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "updated_at",
    "source",
    "stale_after_minutes",
    "status",
    "status_message",
    "boards"
  ],
  "properties": {
    "updated_at": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "stale_after_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error"]
    },
    "status_message": {
      "type": "string"
    },
    "boards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "board_id",
          "title",
          "anchor",
          "description",
          "fundamentals_placeholder",
          "industries"
        ],
        "properties": {
          "board_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "anchor": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "fundamentals_placeholder": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "description", "planned_metrics"],
            "properties": {
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "planned_metrics": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "industries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "ts_code",
                "name",
                "market",
                "enabled",
                "status",
                "status_message"
              ],
              "properties": {
                "ts_code": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "market": {
                  "type": "string",
                  "minLength": 1
                },
                "enabled": {
                  "type": "boolean"
                },
                "status": {
                  "type": "string",
                  "enum": ["ready", "partial", "error", "coming_soon"]
                },
                "status_message": {
                  "type": "string"
                },
                "latest_trade_date": {
                  "type": "string"
                },
                "latest_close": {
                  "type": "number"
                },
                "latest_pct_change": {
                  "type": "number"
                },
                "pb": {
                  "type": "number"
                },
                "amount": {
                  "type": "number"
                },
                "float_mv": {
                  "type": "number"
                },
                "member_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "pb_percentiles": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["three_year", "five_year"],
                  "properties": {
                    "three_year": {
                      "type": ["number", "null"]
                    },
                    "five_year": {
                      "type": ["number", "null"]
                    }
                  }
                },
                "crowdedness": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["amount_pct", "turnover_ratio_pct", "score", "label"],
                  "properties": {
                    "amount_pct": {
                      "type": ["number", "null"]
                    },
                    "turnover_ratio_pct": {
                      "type": ["number", "null"]
                    },
                    "score": {
                      "type": ["number", "null"]
                    },
                    "label": {
                      "type": "string"
                    }
                  }
                },
                "pb_roe_alignment": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "pb_pct_3y",
                    "pb_pct_5y",
                    "roe_pct_20q",
                    "current_roe",
                    "current_roe_period",
                    "match_gap",
                    "status",
                    "label"
                  ],
                  "properties": {
                    "pb_pct_3y": {
                      "type": ["number", "null"]
                    },
                    "pb_pct_5y": {
                      "type": ["number", "null"]
                    },
                    "roe_pct_20q": {
                      "type": ["number", "null"]
                    },
                    "current_roe": {
                      "type": ["number", "null"]
                    },
                    "current_roe_period": {
                      "type": ["string", "null"]
                    },
                    "match_gap": {
                      "type": ["number", "null"]
                    },
                    "status": {
                      "type": "string",
                      "enum": ["expensive_vs_roe", "balanced", "cheap_vs_roe", "empty"]
                    },
                    "label": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
