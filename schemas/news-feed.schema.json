{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["updated_at", "source", "stale_after_minutes", "items"],
  "properties": {
    "updated_at": { "type": "string" },
    "source": { "type": "string" },
    "stale_after_minutes": { "type": "integer", "minimum": 1 },
    "status": { "type": "string" },
    "status_message": { "type": "string" },
    "counts": {
      "type": "object",
      "required": ["approved", "pending"],
      "properties": {
        "approved": { "type": "integer", "minimum": 0 },
        "pending": { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "source", "url", "published_at", "tags", "summary", "review_status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "source": { "type": "string" },
          "url": { "type": "string" },
          "published_at": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "summary": { "type": "string" },
          "review_status": { "const": "approved" }
        }
      }
    }
  }
}
