    "leaflet": "^1.9.4",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/leaflet": "^1.9.18",
    "@types/node": "^24.0.1",
    "typescript": "^5.8.3"
  }
